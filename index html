<script>
(function(){
  const audio = document.getElementById('audio');
  const list  = document.getElementById('trackList');
  const player= document.getElementById('player');
  const pTitle= document.getElementById('pTitle');
  const pFill = document.getElementById('pFill');
  const pBar  = document.getElementById('pBar');
  const pTime = document.getElementById('pTime');
  const btnPlay = document.getElementById('btnPlay');
  const iconPlay= document.getElementById('iconPlay');
  document.getElementById('yr').textContent = new Date().getFullYear();

  // ---- Full-album zip, built in the browser from the repo's own mp3s ----
  const zipBtn = document.getElementById('zipBtn');
  const zipNote = document.getElementById('zipNote');
  let zipping = false;
  zipBtn.addEventListener('click', async function(){
    if(zipping) return;
    zipping = true;
    zipBtn.disabled = true;
    try{
      zipBtn.textContent = 'Loading…';
      if(!window.JSZip){
        await new Promise(function(res, rej){
          const s = document.createElement('script');
          s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
          s.onload = res; s.onerror = rej;
          document.head.appendChild(s);
        });
      }
      const zip = new JSZip();
      for(let i = 0; i < TRACKS.length; i++){
        zipBtn.textContent = 'Packing ' + (i+1) + ' / ' + TRACKS.length + '…';
        const r = await fetch(AUDIO_DIR + TRACKS[i].file);
        if(!r.ok) throw new Error(TRACKS[i].file);
        zip.file(TRACKS[i].file, await r.arrayBuffer());
      }
      zipBtn.textContent = 'Building zip…';
      const blob = await zip.generateAsync({ type:'blob', compression:'STORE' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'The_Ryder_McCoy_Band_-_The_Warning.zip';
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(function(){ URL.revokeObjectURL(url); }, 60000);
      zipBtn.textContent = 'Download Full Album (.zip)';
    }catch(err){
      zipBtn.textContent = 'Download Full Album (.zip)';
      zipNote.textContent = 'Album download hit a snag — grab tracks one at a time with the arrows above.';
    }finally{
      zipping = false;
      zipBtn.disabled = false;
    }
  });
  document.getElementById('bookingLink').href = 'mailto:' + BOOKING_EMAIL + '?subject=Booking%20%E2%80%94%20The%20Ryder%20McCoy%20Band';
  const sr = document.getElementById('socialRow');
  SOCIALS.forEach(function(s){
    const a = document.createElement('a');
    a.href = s.url; a.textContent = s.name;
    a.target = '_blank'; a.rel = 'noopener';
    a.className = 'type';
    a.style.cssText = 'color:var(--ash);text-decoration:none;letter-spacing:.14em;text-transform:uppercase;font-size:.8rem;border-bottom:1px solid var(--line);padding-bottom:2px';
    sr.appendChild(a);
  });

  let current = -1;

  const PLAY = 'M3 2l11 6-11 6z';
  const PAUSE= 'M3 2h3.5v12H3zM9.5 2H13v12H9.5z';

  function fmt(s){
    if(!isFinite(s)) return '0:00';
    s = Math.floor(s);
    return Math.floor(s/60) + ':' + String(s%60).padStart(2,'0');
  }

  // Build rows
  TRACKS.forEach(function(t, i){
    const row = document.createElement('div');
    row.className = 'track';
    row.setAttribute('role','listitem');
    row.innerHTML =
      '<span class="t-num">' + String(i+1).padStart(2,'0') + '</span>' +
      '<span class="t-title">' + t.title + '</span>' +
      '<span class="t-dur" id="dur' + i + '">--:--</span>' +
      '<span style="display:flex;gap:8px">' +
        '<button class="icon-btn js-play" data-i="' + i + '" aria-label="Play ' + t.title + '"><svg viewBox="0 0 16 16"><path d="' + PLAY + '"/></svg></button>' +
        '<a class="icon-btn" href="' + AUDIO_DIR + t.file + '" download aria-label="Download ' + t.title + '"><svg viewBox="0 0 16 16"><path d="M7 1h2v6.6l1.8-1.8 1.4 1.4L8 11.4 3.8 7.2l1.4-1.4L7 7.6z"/><path d="M2 13h12v2H2z"/></svg></a>' +
      '</span>';
    list.appendChild(row);

    // fetch duration lazily
    const probe = document.createElement('audio');
    probe.preload = 'metadata';
    probe.src = AUDIO_DIR + t.file;
    probe.addEventListener('loadedmetadata', function(){
      document.getElementById('dur' + i).textContent = fmt(probe.duration);
    });
  });

  function setRowStates(){
    document.querySelectorAll('.track').forEach(function(r, i){
      r.classList.toggle('active', i === current);
      const btn = r.querySelector('.js-play svg path');
      btn.setAttribute('d', (i === current && !audio.paused) ? PAUSE : PLAY);
    });
    iconPlay.querySelector('path') ? iconPlay.querySelector('path').setAttribute('d', audio.paused ? PLAY : PAUSE)
                                   : null;
  }

  function load(i, play){
    current = ((i % TRACKS.length) + TRACKS.length) % TRACKS.length;
    audio.src = AUDIO_DIR + TRACKS[current].file;
    pTitle.textContent = String(current+1).padStart(2,'0') + ' — ' + TRACKS[current].title;
    player.classList.add('show');
    if(play) audio.play();
    setRowStates();
  }

  list.addEventListener('click', function(e){
    const b = e.target.closest('.js-play');
    if(!b) return;
    const i = parseInt(b.dataset.i, 10);
    if(i === current){
      audio.paused ? audio.play() : audio.pause();
    } else {
      load(i, true);
    }
  });

  btnPlay.addEventListener('click', function(){
    if(current === -1){ load(0, true); return; }
    audio.paused ? audio.play() : audio.pause();
  });
  document.getElementById('btnNext').addEventListener('click', function(){ load(current + 1, true); });
  document.getElementById('btnPrev').addEventListener('click', function(){
    if(audio.currentTime > 3){ audio.currentTime = 0; } else { load(current - 1, true); }
  });

  audio.addEventListener('play', setRowStates);
  audio.addEventListener('pause', setRowStates);
  audio.addEventListener('ended', function(){
    if(current < TRACKS.length - 1) load(current + 1, true);
    else setRowStates();
  });
  audio.addEventListener('timeupdate', function(){
    const pct = audio.duration ? (audio.currentTime / audio.duration * 100) : 0;
    pFill.style.width = pct + '%';
    pBar.setAttribute('aria-valuenow', Math.round(pct));
    pTime.textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
  });

  function seek(clientX){
    const r = pBar.getBoundingClientRect();
    const pct = Math.min(1, Math.max(0, (clientX - r.left) / r.width));
    if(audio.duration) audio.currentTime = pct * audio.duration;
  }
  pBar.addEventListener('click', function(e){ seek(e.clientX); });
  pBar.addEventListener('keydown', function(e){
    if(!audio.duration) return;
    if(e.key === 'ArrowRight'){ audio.currentTime = Math.min(audio.duration, audio.currentTime + 5); }
    if(e.key === 'ArrowLeft'){ audio.currentTime = Math.max(0, audio.currentTime - 5); }
  });
})();
</script>
</body>
</html>
