<style>
  :root{
    --asphalt:#0b0a08;
    --smoke:#171310;
    --panel:#1d1813;
    --neon:#ff8a2a;
    --neon-hot:#ffc27a;
    --crimson:#a31f1f;
    --bone:#e9e0cf;
    --ash:#9a8f7e;
    --line:#2c241c;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:var(--asphalt);
    color:var(--bone);
    font-family:Georgia,'Times New Roman',serif;
    font-size:17px;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  ::selection{background:var(--crimson);color:var(--bone)}
  a{color:var(--neon-hot)}
  img{max-width:100%;display:block}

  .display{font-family:'Anton',sans-serif;text-transform:uppercase;letter-spacing:.04em;font-weight:400}
  .type{font-family:'Special Elite',monospace}

  .wrap{max-width:880px;margin:0 auto;padding:0 20px}

  /* ============ HERO ============ */
  .hero{
    min-height:92vh;
    display:flex;flex-direction:column;justify-content:flex-end;align-items:center;
    text-align:center;position:relative;overflow:hidden;
    padding:80px 20px 70px;
    background:
      linear-gradient(to bottom, rgba(11,10,8,.55) 0%, rgba(11,10,8,.25) 40%, rgba(11,10,8,.92) 82%, var(--asphalt) 100%),
      url('images/hero-stage.jpg') center 30% / cover no-repeat,
      var(--asphalt);
  }
  .hero::after{ /* wet asphalt sheen */
    content:"";position:absolute;inset:auto 0 0 0;height:38%;
    background:linear-gradient(to top, rgba(255,138,42,.05), transparent);
    pointer-events:none;
  }
  .eyebrow{
    color:var(--ash);font-size:.8rem;letter-spacing:.28em;text-transform:uppercase;
    margin-bottom:26px;
  }
  .neon{
    font-family:'Anton',sans-serif;text-transform:uppercase;
    font-size:clamp(2.6rem,10vw,5.8rem);
    line-height:.95;letter-spacing:.03em;
    color:var(--neon-hot);
    text-shadow:
      0 0 6px rgba(255,170,90,.9),
      0 0 22px rgba(255,138,42,.65),
      0 0 60px rgba(255,138,42,.45),
      0 0 120px rgba(255,138,42,.28);
    animation:buzz 6s infinite;
  }
  .neon .dim{ /* one letter wired bad */
    animation:badwire 6s infinite;
  }
  @keyframes buzz{
    0%,93%,100%{opacity:1}
    94%{opacity:.86}
    95%{opacity:1}
    97.5%{opacity:.92}
    98%{opacity:1}
  }
  @keyframes badwire{
    0%,18%,23%,61%,64%,100%{opacity:1;text-shadow:inherit}
    19%,22%{opacity:.25;text-shadow:none}
    62%,63%{opacity:.4;text-shadow:none}
  }
  @media (prefers-reduced-motion: reduce){
    .neon,.neon .dim{animation:none}
    html{scroll-behavior:auto}
  }
  .hero h2{
    font-size:clamp(1.05rem,3vw,1.45rem);
    letter-spacing:.32em;margin-top:22px;color:var(--bone);
  }
  .hero p.tag{
    margin-top:26px;color:var(--ash);max-width:46ch;font-style:italic;
  }
  .cta-row{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:38px}
  .btn{
    display:inline-block;padding:15px 30px;text-decoration:none;
    font-family:'Anton',sans-serif;text-transform:uppercase;letter-spacing:.12em;font-size:1rem;
    border:1px solid var(--neon);color:var(--neon-hot);background:transparent;
    transition:background .2s,color .2s,box-shadow .2s;cursor:pointer;
  }
  .btn:hover,.btn:focus-visible{background:var(--neon);color:#1a0e02;box-shadow:0 0 28px rgba(255,138,42,.5)}
  .btn.solid{background:var(--crimson);border-color:var(--crimson);color:var(--bone)}
  .btn.solid:hover,.btn.solid:focus-visible{background:#c22727;box-shadow:0 0 28px rgba(163,31,31,.55)}
  :focus-visible{outline:2px solid var(--neon-hot);outline-offset:3px}

  /* ============ SECTIONS ============ */
  section{padding:84px 0;border-top:1px solid var(--line)}
  .sec-label{
    font-family:'Special Elite',monospace;color:var(--neon);
    font-size:.85rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:14px;
  }
  .sec-title{font-size:clamp(1.9rem,5vw,2.8rem);margin-bottom:18px;color:var(--bone)}
  .lede{color:var(--ash);max-width:62ch}

  /* ============ TRACK LOG ============ */
  .log{margin-top:42px;border:1px solid var(--line);background:var(--smoke)}
  .log-head{
    display:flex;justify-content:space-between;align-items:center;gap:12px;
    padding:14px 18px;border-bottom:1px dashed var(--line);
    font-family:'Special Elite',monospace;font-size:.78rem;color:var(--ash);
    letter-spacing:.14em;text-transform:uppercase;
  }
  .track{
    display:grid;grid-template-columns:52px 1fr auto auto;align-items:center;gap:12px;
    padding:15px 18px;border-bottom:1px solid var(--line);
    transition:background .15s;
  }
  .track:last-child{border-bottom:none}
  .track:hover{background:var(--panel)}
  .track.active{background:var(--panel);box-shadow:inset 3px 0 0 var(--neon)}
  .t-num{
    font-family:'Special Elite',monospace;color:var(--ash);font-size:.95rem;
  }
  .track.active .t-num{color:var(--neon)}
  .t-title{font-size:1.05rem;color:var(--bone);min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .t-dur{font-family:'Special Elite',monospace;font-size:.85rem;color:var(--ash)}
  .icon-btn{
    background:none;border:1px solid var(--line);color:var(--bone);
    width:42px;height:42px;display:flex;align-items:center;justify-content:center;
    cursor:pointer;transition:border-color .15s,color .15s,background .15s;
  }
  .icon-btn:hover,.icon-btn:focus-visible{border-color:var(--neon);color:var(--neon-hot)}
  .icon-btn svg{width:16px;height:16px;fill:currentColor}
  a.icon-btn{text-decoration:none}

  .dl-all{margin-top:30px;text-align:center}
  .dl-note{margin-top:14px;font-family:'Special Elite',monospace;font-size:.8rem;color:var(--ash);letter-spacing:.08em}

  /* ============ ABOUT ============ */
  .band-grid{display:grid;gap:26px;margin-top:38px}
  @media(min-width:640px){.band-grid{grid-template-columns:repeat(3,1fr)}}
  .member{border:1px solid var(--line);background:var(--smoke);padding:24px}
  .member h3{font-size:1.25rem;color:var(--neon-hot);margin-bottom:4px}
  .member .role{font-family:'Special Elite',monospace;font-size:.75rem;color:var(--ash);letter-spacing:.16em;text-transform:uppercase;margin-bottom:12px}
  .member p{font-size:.95rem;color:var(--bone)}

  /* ============ PLAYER BAR ============ */
  .player{
    position:fixed;left:0;right:0;bottom:0;z-index:50;
    background:rgba(13,11,9,.97);border-top:1px solid var(--neon);
    box-shadow:0 -8px 40px rgba(0,0,0,.7);
    transform:translateY(110%);transition:transform .3s ease;
    padding:10px 16px calc(10px + env(safe-area-inset-bottom));
  }
  .player.show{transform:translateY(0)}
  .p-inner{max-width:880px;margin:0 auto;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center}
  .p-controls{display:flex;gap:8px}
  .p-meta{min-width:0}
  .p-title{font-size:.95rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .p-bar{height:4px;background:var(--line);margin-top:8px;cursor:pointer;position:relative}
  .p-fill{height:100%;width:0%;background:var(--neon);box-shadow:0 0 10px rgba(255,138,42,.7)}
  .p-time{font-family:'Special Elite',monospace;font-size:.75rem;color:var(--ash);white-space:nowrap}

  /* ============ FOOTER ============ */
  footer{
    border-top:1px solid var(--line);padding:56px 20px calc(110px + env(safe-area-inset-bottom));
    text-align:center;color:var(--ash);font-size:.9rem;
  }
  footer .label-mark{
    font-family:'Special Elite',monospace;letter-spacing:.2em;text-transform:uppercase;
    color:var(--bone);margin-bottom:10px;
  }
  footer .fine{font-size:.78rem;margin-top:18px;max-width:52ch;margin-left:auto;margin-right:auto}
</style>
</head>
